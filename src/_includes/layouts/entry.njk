---
layout: base.njk
---
<section class="view active">
  <div class="wrap" style="max-width:820px">

    <a class="label" href="{% if type == 'research' %}/research/{% else %}/magazine/{% endif %}" style="display:inline-block;margin-bottom:1.2rem;text-decoration:none"
       data-en="{% if type == 'research' %}← Research{% else %}← Magazine{% endif %}"
       data-ar="{% if type == 'research' %}← الأبحاث{% else %}← المجلّة{% endif %}"></a>

    <div class="meta" style="margin-bottom:14px">
      <span class="tag" data-en="{{ categories[type][category].en }}" data-ar="{{ categories[type][category].ar }}"></span>
      {% if featured %}<span class="tag sky" data-en="Featured" data-ar="مميّز"></span>{% endif %}
      {% if status == "preparation" %}<span class="tag soft" data-en="In preparation" data-ar="قيد الإعداد"></span>{% endif %}
    </div>

    <h2 style="font-size:clamp(1.8rem,3.6vw,2.7rem)" data-en="{{ title_en }}" data-ar="{{ title_ar }}"></h2>
    <p class="lede" style="margin-top:1rem" data-en="{{ why_en }}" data-ar="{{ why_ar }}"></p>

    {% if date_created %}
      {% set bylineEn = (author_en or 'Mudun') + ' · Produced ' + (date_created | formatDate('en')) + ' · Published on Mudun ' + (date | formatDate('en')) %}
      {% set bylineAr = (author_ar or 'مدن') + ' · أُنتج في ' + (date_created | formatDate('ar')) + ' · نُشر على مدن في ' + (date | formatDate('ar')) %}
    {% else %}
      {% set bylineEn = (author_en or 'Mudun') + ' · ' + (date | formatDate('en')) %}
      {% set bylineAr = (author_ar or 'مدن') + ' · ' + (date | formatDate('ar')) %}
    {% endif %}
    <p class="byline" style="margin-top:.6rem;color:var(--asphalt-soft);font-size:.92rem"
       data-en="{{ bylineEn }}"
       data-ar="{{ bylineAr }}"></p>

    {% if status == "preparation" %}
      <div class="note" style="margin-top:clamp(30px,4vw,44px)">
        <div class="label" data-en="In preparation" data-ar="قيد الإعداد"></div>
        <p style="margin-top:.8rem"
           data-en="This piece is currently being prepared. It will appear here in full once it's ready."
           data-ar="هذه المادة قيد الإعداد حاليًا. وستظهر هنا كاملةً بمجرد أن تصبح جاهزة."></p>
      </div>

    {% else %}

      {% if cover %}
        <img src="{{ cover }}" alt="" style="width:100%;border-radius:6px;margin:clamp(24px,4vw,36px) 0">
      {% endif %}

      {# ---- Layer 1: the brief ---- #}
      <div style="margin-top:clamp(28px,4vw,40px)">
        <h4 style="font-family:var(--label-font);font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--green-deep);margin:0 0 8px"
            data-en="{% if type == 'research' %}Why it matters{% else %}The piece{% endif %}"
            data-ar="{% if type == 'research' %}لماذا يهمّ{% else %}المادة{% endif %}"></h4>

        <div class="prose" data-only="en">{{ brief_en | markdownify | safe }}</div>
        <div class="prose" data-only="ar" dir="rtl">{{ brief_ar | markdownify | safe }}</div>
      </div>

      {% if type == "magazine" and topics and topics.length %}
        <div style="margin-top:14px;display:flex;flex-wrap:wrap;gap:6px">
          {% for t in topics %}<span class="tag">{{ t }}</span>{% endfor %}
        </div>
      {% endif %}

      {% if not cover %}
        <div class="figure">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="m3 14 5-4 4 3 5-5 4 3"/><circle cx="8.5" cy="8.5" r="1.4"/></svg>
          <span data-en="Figure or chart — provided by the researcher" data-ar="رسمٌ أو مخطّط — يقدّمه الباحث"></span>
        </div>
      {% endif %}

      {# ---- Research-only: what the study examines ---- #}
      {% if type == "research" and examines_en and examines_en.length %}
        <h4 style="font-family:var(--label-font);font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--green-deep);margin:22px 0 8px"
            data-en="What this study examines" data-ar="ما الذي تتناوله الدراسة"></h4>
        <ul style="margin:0 0 18px;padding-inline-start:1.1em;color:var(--asphalt-soft)">
          {% for i in range(0, examines_en.length) %}
            <li style="margin-bottom:6px" data-en="{{ examines_en[i] }}" data-ar="{{ examines_ar[i] }}"></li>
          {% endfor %}
        </ul>
      {% endif %}

      {# ---- Presentation slides (self-hosted, bilingual) ---- #}
      {% if type == "research" and (slides_en.length or slides_ar.length) %}
        <h4 style="font-family:var(--label-font);font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--green-deep);margin:28px 0 8px"
            data-en="Presentation" data-ar="العرض التقديمي"></h4>

        {% if slides_en.length %}
        <div data-only="en">
          <div class="slide-viewer" id="slides-en">
            {% for s in slides_en %}<img src="{{ s | slideUrl }}" alt="Slide {{ loop.index }} of {{ slides_en.length }}" loading="lazy">{% endfor %}
          </div>
          <div class="slide-nav">
            <button type="button" class="btn btn-ghost btn-sm" onclick="openLightbox('slides-en')" data-en="View presentation full screen ⤢" data-ar="مشاهدة العرض التقديمي بملء الشاشة ⤢" style="margin-inline-end:auto"></button>
            <button type="button" aria-label="Previous slide" onclick="document.getElementById('slides-en').scrollBy({left:-320,behavior:'smooth'})">‹</button>
            <button type="button" aria-label="Next slide" onclick="document.getElementById('slides-en').scrollBy({left:320,behavior:'smooth'})">›</button>
          </div>
        </div>
        {% endif %}

        {% if slides_ar.length %}
        <div data-only="ar">
          <div class="slide-viewer" id="slides-ar" dir="rtl">
            {% for s in slides_ar %}<img src="{{ s | slideUrl }}" alt="الشريحة {{ loop.index }} من {{ slides_ar.length }}" loading="lazy">{% endfor %}
          </div>
          <div class="slide-nav">
            <button type="button" class="btn btn-ghost btn-sm" onclick="openLightbox('slides-ar')" data-en="View presentation full screen ⤢" data-ar="مشاهدة العرض التقديمي بملء الشاشة ⤢" style="margin-inline-end:auto"></button>
            <button type="button" aria-label="الشريحة السابقة" onclick="document.getElementById('slides-ar').scrollBy({left:320,behavior:'smooth'})">›</button>
            <button type="button" aria-label="الشريحة التالية" onclick="document.getElementById('slides-ar').scrollBy({left:-320,behavior:'smooth'})">‹</button>
          </div>
        </div>
        {% endif %}

        <div id="lightbox" class="lightbox" onclick="if(event.target===this)closeLightbox()">
          <button type="button" class="lightbox-close" aria-label="Close" onclick="closeLightbox()">✕</button>
          <button type="button" class="lightbox-arrow lightbox-prev" aria-label="Previous" onclick="lightboxNav(-1)">‹</button>
          <img id="lightbox-img" src="" alt="">
          <button type="button" class="lightbox-arrow lightbox-next" aria-label="Next" onclick="lightboxNav(1)">›</button>
        </div>
      {% endif %}

      {# ---- Layer 2: the full study PDF ---- #}
      {% if type == "research" %}
        <div style="margin-top:clamp(28px,4vw,40px);padding-top:clamp(20px,3vw,28px);border-top:1px solid var(--sand-line)">
        <h4 style="font-family:var(--label-font);font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--green-deep);margin:0 0 8px"
            data-en="Full study" data-ar="الدراسة الكاملة"></h4>
        {% if pdf %}
          <div class="pdf-actions">
            <a class="btn btn-primary" href="{{ pdf }}" download>
              <span data-en="Download full PDF" data-ar="تحميل الدراسة (PDF)"></span><span class="arrow">↓</span>
            </a>
            <a class="btn btn-ghost" href="{{ pdf }}" target="_blank" rel="noopener">
              <span data-en="View in browser" data-ar="عرض في المتصفح"></span>
            </a>
          </div>
        {% else %}
          <p class="privacy" data-en="The full study PDF will be attached here soon." data-ar="سيُرفَق ملف الدراسة الكامل هنا قريبًا."></p>
        {% endif %}
        </div>
      {% endif %}

    {% endif %}

  </div>
</section>
