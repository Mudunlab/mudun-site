---
layout: base.njk
title: "Join Mudun — Free membership · Add your name"
description: "Membership in Mudun is free and always will be. Add your name to help build a public voice for people-centered urban planning in Jordan and the region."
---
  <section class="view active" id="view-join">
    <div class="wrap">
      <div class="invite">
        <div class="label" data-en="Membership" data-ar="العضوية"></div>
        <h2 data-en="Membership is free — and always will be." data-ar="العضوية مجّانية — وستبقى كذلك دائمًا."></h2>
        <p data-en="It isn't a subscription and we don't sell it. Adding your name is a way of saying you believe Jordan's cities should be built for the people who live in them. That's it — that's the whole thing."
           data-ar="ليست اشتراكًا ولا نبيعها. إضافة اسمك طريقةٌ لتقول إنك تؤمن بأنّ مدن الأردن يجب أن تُبنى لمن يعيشون فيها. هذا كلّ شيء."></p>
        <div class="stamp" data-en="An invitation, not a product." data-ar="دعوةٌ، لا منتج."></div>
      </div>

      <div class="sec-head" style="margin-bottom:24px">
        <span class="label" data-en="Join Mudun" data-ar="انضمّ إلى مدن"></span>
        <h2 data-en="Add your name" data-ar="أضف اسمك"></h2>
      </div>

      <form class="form-wrap" id="joinForm" action="https://formspree.io/f/maqgznql" method="POST" novalidate>
        <div class="field"><label data-en="Full name" data-ar="الاسم الكامل"></label><input type="text" name="name" required data-en-ph="Your name" data-ar-ph="اسمك"></div>
        <div class="field"><label data-en="Email" data-ar="البريد الإلكتروني"></label><input type="email" name="email" required data-en-ph="you@example.com" data-ar-ph="you@example.com"></div>
        <div class="field"><label data-en="City" data-ar="المدينة"></label><input type="text" name="city" data-en-ph="Amman" data-ar-ph="عمّان"></div>
        <div class="field"><label data-en="Profession / field of study" data-ar="المهنة / مجال الدراسة"></label><input type="text" name="profession" data-en-ph="e.g. urban planning, architecture, engineering, student" data-ar-ph="مثلاً: التخطيط الحضري، العمارة، الهندسة، طالب"></div>
        <div class="field">
          <label data-en="How would you like to be involved?" data-ar="كيف تودّ أن تشارك؟"></label>
          <div class="checks">
            <label class="check"><input type="checkbox" name="involvement" value="Writing & research"><span data-en="Writing &amp; research" data-ar="الكتابة والبحث"></span></label>
            <label class="check"><input type="checkbox" name="involvement" value="Volunteering"><span data-en="Volunteering" data-ar="التطوّع"></span></label>
            <label class="check"><input type="checkbox" name="involvement" value="Data collection"><span data-en="Data collection" data-ar="جمع البيانات"></span></label>
            <label class="check"><input type="checkbox" name="involvement" value="Photography & mapping"><span data-en="Photography &amp; mapping" data-ar="التصوير ورسم الخرائط"></span></label>
            <label class="check"><input type="checkbox" name="involvement" value="Events"><span data-en="Events" data-ar="الفعاليات"></span></label>
            <label class="check"><input type="checkbox" name="involvement" value="Just here to support"><span data-en="Just here to support" data-ar="هنا للدعم فقط"></span></label>
          </div>
        </div>
        <div class="field"><label data-en="Why do you want to join? (optional)" data-ar="لماذا تودّ الانضمام؟ (اختياري)"></label><textarea name="why" data-en-ph="A sentence or two, if you'd like." data-ar-ph="جملة أو جملتان، إن أحببت."></textarea></div>
        <button type="submit" class="btn btn-primary" data-en="Join Mudun (free)" data-ar="انضمّ إلى مدن (مجّانًا)"></button>
        <p class="privacy" data-en="We'll only use your details to send occasional updates when new work is published. We won't share them." data-ar="سنستخدم بياناتك فقط لإرسال تحديثاتٍ من حينٍ لآخر عند نشر أعمالٍ جديدة. ولن نشاركها."></p>
      </form>
      <div class="form-ok" id="joinOk">
        <h3 data-en="You're on the list." data-ar="أصبحت على القائمة."></h3>
        <p data-en="Welcome to Mudun. We'll email you when new work goes up." data-ar="أهلًا بك في مدن. سنراسلك عند نشر أعمالٍ جديدة."></p>
      </div>
    </div>
  </section>
