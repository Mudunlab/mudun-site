{% macro card(entry, type, cats) %}
        <article class="entry" data-cat="{{ entry.data.category }}">
          <div class="meta">
            <span class="tag" data-en="{{ cats[type][entry.data.category].en }}" data-ar="{{ cats[type][entry.data.category].ar }}"></span>
            {% if entry.data.featured %}<span class="tag sky" data-en="Featured" data-ar="مميّز"></span>{% endif %}
            {% if entry.data.status == "preparation" %}<span class="tag soft" data-en="In preparation" data-ar="قيد الإعداد"></span>{% endif %}
          </div>
          <h3><a href="{{ entry.url }}" style="color:inherit;text-decoration:none" data-en="{{ entry.data.title_en }}" data-ar="{{ entry.data.title_ar }}"></a></h3>
          <p class="why"{% if entry.data.status == "preparation" %} style="margin:0"{% endif %} data-en="{{ entry.data.why_en }}" data-ar="{{ entry.data.why_ar }}"></p>
          {% if entry.data.status != "preparation" %}
          <a class="entry-toggle" href="{{ entry.url }}" style="text-decoration:none">
            <span class="plus">→</span><span data-en="Read the brief" data-ar="اقرأ الملخّص"></span>
          </a>
          {% endif %}
        </article>
{% endmacro %}
